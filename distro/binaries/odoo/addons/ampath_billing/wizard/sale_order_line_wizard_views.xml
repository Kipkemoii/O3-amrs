<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard form view -->
        <record id="view_sale_order_line_wizard_form" model="ir.ui.view">
            <field name="name">sale.order.line.wizard.form</field>
            <field name="model">sale.order.line.wizard</field>
            <field name="arch" type="xml">
                <form string="Bulk Actions on Order Lines">
                    <field name="order_id" invisible="1"/>
                    <group>
                        <p class="text-muted">
                            Select the order lines you want to act on, then click an action button below.
                        </p>
                    </group>
                    <field name="line_ids" widget="many2many">
                        <tree editable="bottom">
                            <field name="product_id" readonly="1"/>
                            <field name="name" readonly="1" string="Description"/>
                            <field name="product_uom_qty" readonly="1" string="Qty"/>
                            <field name="price_unit" readonly="1"/>
                            <field name="discount" readonly="1"/>
                            <field name="price_subtotal" readonly="1" string="Subtotal"/>
                            <field name="insurance_provider_id" readonly="1"/>
                            <field name="claim_status" widget="badge" readonly="1"
                                   decoration-info="claim_status == 'submitted'"
                                   decoration-success="claim_status == 'approved'"/>
                        </tree>
                    </field>
                    <footer>
                        <button name="action_waive" type="object"
                                string="Waive Selected" class="btn-secondary"
                                confirm="Apply 100% discount to the selected lines?"/>
                        <button name="action_claim" type="object"
                                string="Claim Selected" class="btn-secondary"
                                confirm="Submit FHIR claims for the selected lines?"/>
                        <button name="action_pay" type="object"
                                string="Pay Selected" class="btn-primary"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action to open the wizard -->
        <record id="action_sale_order_line_wizard" model="ir.actions.act_window">
            <field name="name">Bulk Actions</field>
            <field name="res_model">sale.order.line.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
        </record>
    </data>
</odoo>
