<odoo>
    <data>
        <record id="view_sale_advance_payment_inv_ampath" model="ir.ui.view">
            <field name="name">sale.advance.payment.inv.ampath</field>
            <field name="model">sale.advance.payment.inv</field>
            <field name="arch" type="xml">
                <form string="Pay Selected Items">
                    <sheet>
                        <group>
                            <field name="advance_payment_method" readonly="1"/>
                            <field name="fixed_amount" readonly="1"
                                   string="Amount to Pay"
                                   widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Products">
                            <field name="ampath_product_summary"
                                   nolabel="1" readonly="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="create_invoices" type="object"
                                string="Create Down Payment Invoice"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
