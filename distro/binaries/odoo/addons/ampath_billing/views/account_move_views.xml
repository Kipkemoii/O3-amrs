<odoo>
    <data>
        <record id="view_move_form_ampath_inherit" model="ir.ui.view">
            <field name="name">account.move.form.ampath</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/tree" position="inside">
                    <field name="insurance_provider_id" optional="hide"/>
                    <field name="claim_status" widget="badge"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>