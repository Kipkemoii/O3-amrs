<odoo>
    <data>
        <record id="view_order_form_ampath_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.ampath</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']" position="before">
                    <button name="%(ampath_billing.action_sale_order_line_wizard)d"
                            type="action" string="⚡ Bulk Actions"
                            class="btn-secondary mb-2"
                            icon="fa-tasks"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/tree" position="inside">
                    <field name="insurance_provider_id" optional="show"/>
                    <field name="claim_status" widget="badge"
                           decoration-info="claim_status == 'submitted'"
                           decoration-success="claim_status == 'approved'"/>
                    <button name="action_bulk_waive" type="object"
                            string="Waive" class="btn-link"/>
                    <button name="action_bulk_fhir_claim" type="object"
                            string="Claim" class="btn-link"/>
                    <button name="action_bulk_individual_payment" type="object"
                            string="Pay" class="btn-link"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>