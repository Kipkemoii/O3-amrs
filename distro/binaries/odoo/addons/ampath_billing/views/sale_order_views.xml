<odoo>
    <data>
        <record id="view_order_form_ampath_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.ampath</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/tree" position="inside">
                    <field name="insurance_provider_id" optional="show"/>
                    <field name="claim_status" widget="badge"
                           decoration-info="claim_status == 'submitted'"
                           decoration-success="claim_status == 'approved'"/>
                </xpath>
            </field>
        </record>

        <record id="action_so_line_bulk_waive" model="ir.actions.server">
            <field name="name">AMPATH: Waive Selected</field>
            <field name="model_id" ref="sale.model_sale_order_line"/>
            <field name="binding_model_id" ref="sale.model_sale_order_line"/>
            <field name="state">code</field>
            <field name="code">records.action_bulk_waive()</field>
        </record>

        <record id="action_so_line_bulk_claim" model="ir.actions.server">
            <field name="name">AMPATH: Submit FHIR Claim</field>
            <field name="model_id" ref="sale.model_sale_order_line"/>
            <field name="binding_model_id" ref="sale.model_sale_order_line"/>
            <field name="state">code</field>
            <field name="code">records.action_bulk_fhir_claim()</field>
        </record>

        <record id="action_so_line_bulk_pay" model="ir.actions.server">
            <field name="name">AMPATH: Pay Selected Items</field>
            <field name="model_id" ref="sale.model_sale_order_line"/>
            <field name="binding_model_id" ref="sale.model_sale_order_line"/>
            <field name="state">code</field>
            <field name="code">action = records.action_bulk_individual_payment()</field>
        </record>
    </data>
</odoo>