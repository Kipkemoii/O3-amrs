{
  "@openmrs/esm-patient-chart-app": {
    "extensionSlots": {
      "patient-chart-dashboard-slot": {
        "add": ["nav-group#GeneralMedicine", "nav-group#MNCH"],
        "order": ["nav-group#GeneralMedicine", "nav-group#MNCH"],
        "configure": {
          "nav-group#GeneralMedicine": {
            "title": "generalMedicine",
            "slotName": "general-medicine-group-slot",
            "isExpanded": true,
            "Translation overrides": {"en": {"generalMedicine": "General Medicine"}}
          },
          "nav-group#MNCH": {
            "title": "mnch",
            "slotName": "mnch-group-slot",
            "isExpanded": true,
            "Translation overrides": {"en": {"mnch": "MNCH"}}
          }
        }
      },
      "general-medicine-group-slot": {
        "add": ["dashboard#general-opd-triage", "dashboard#general-opd-consultation", "dashboard#dental"],
        "order": ["dashboard#general-opd-triage", "dashboard#general-opd-consultation", "dashboard#dental"],
        "configure": {
          "dashboard#general-opd-triage": {
            "title": "generalOpdTriage",
            "path": "general-opd-triage",
            "slot": "general-opd-triage-dashboard-slot",
            "Translation overrides": {"en": {"generalOpdTriage": "Triage"}}
          },
          "dashboard#general-opd-consultation": {
            "title": "generalOpdConsultation",
            "path": "general-opd-consultation",
            "slot": "general-opd-consultation-dashboard-slot",
            "Translation overrides": {"en": {"generalOpdConsultation": "Consultation"}}
          },
          "dashboard#dental": {
            "title": "dental",
            "path": "dental",
            "slot": "dental-dashboard-slot",
            "Translation overrides": {"en": {"dental": "Dental"}}
          }
        }
      },
      "mnch-group-slot": {
        "add": ["dashboard#cwb", "dashboard#anc", "dashboard#pnc", "dashboard#immunisation", "dashboard#family-planning", "dashboard#maternity"],
        "order": ["dashboard#cwb", "dashboard#anc", "dashboard#pnc", "dashboard#immunisation", "dashboard#family-planning", "dashboard#maternity"],
        "configure": {
          "dashboard#cwb": {
            "title": "cwb",
            "path": "cwb",
            "slot": "cwb-dashboard-slot",
            "Translation overrides": {"en": {"cwb": "CWB"}}
          },
          "dashboard#anc": {
            "title": "anc",
            "path": "anc",
            "slot": "anc-dashboard-slot",
            "Translation overrides": {"en": {"anc": "ANC"}}
          },
          "dashboard#pnc": {
            "title": "pnc",
            "path": "pnc",
            "slot": "pnc-dashboard-slot",
            "Translation overrides": {"en": {"pnc": "PNC"}}
          },
          "dashboard#immunisation": {
            "title": "immunisation",
            "path": "immunisation",
            "slot": "immunisation-dashboard-slot",
            "Translation overrides": {"en": {"immunisation": "Immunisation"}}
          },
          "dashboard#family-planning": {
            "title": "familyPlanning",
            "path": "family-planning",
            "slot": "family-planning-dashboard-slot",
            "Translation overrides": {"en": {"familyPlanning": "Family Planning"}}
          },
          "dashboard#maternity": {
            "title": "maternity",
            "path": "maternity",
            "slot": "maternity-dashboard-slot",
            "Translation overrides": {"en": {"maternity": "Maternity"}}
          }
        }
      }
    }
  }
}
