          "nav-group#GeneralMedicine",
          "nav-group#MNCH",
          "nav-group#NCD",
          "nav-group#HTS"
        ],
        "order": [
          "nav-group#GeneralMedicine",
          "nav-group#MNCH",
          "nav-group#NCD",
          "nav-group#HTS"
        ],
        "configure": {
          "nav-group#GeneralMedicine": {
            "title": "generalMedicine",
            "slotName": "general-medicine-group-slot",
            "isExpanded": true,
            "Translation overrides": {
              "en": {
                "generalMedicine": "General Medicine"
              }
            }
          },
          "nav-group#MNCH": {
            "title": "mnch",
            "slotName": "mnch-group-slot",
