# Example env for docker-compose-odoo.yml. Copy to .env.odoo and run:
#   docker compose -f docker-compose-odoo.yml --env-file .env.odoo up -d
# Or export variables and run without --env-file.

# Host
SERVER_SCHEME=http
HOST_NAME=localhost
ODOO_HOSTNAME=${HOST_NAME}:8069

# Postgres (Odoo DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DATADIR=postgresql-data

# MySQL (EIP DB; optional OpenMRS)
MYSQL_ROOT_PASSWORD=password
MYSQL_PORT=3306
MYSQL_DATADIR=mysql-data

# Odoo
ODOO_DATABASE=odoo
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=password
ODOO_USER=admin
ODOO_PASSWORD=admin
ODOO_PUBLIC_PORT=8069
ODOO_ADDONS=sale_management,stock,account_account,purchase,mrp,odoo_initializer,mrp_product_expiry,product_expiry,l10n_generic_coa
ODOO_FILESTORE=odoo-filestore
ODOO_CONFIG_PATH=odoo-config
ODOO_CONFIG_FILE_PATH=odoo-config
ODOO_CONFIG_CHECKSUMS_PATH=odoo-checksums
ODOO_EXTRA_ADDONS=odoo-extra-addons

# FHIR Odoo
FHIR_ODOO_PUBLIC_PORT=8083
EIP_ODOO_DRUGS_CATEGORY_EXT_ID=categ_products_drug_orders

# EIP Odoo–OpenMRS (when running with O3-amrs backend)
EIP_DB_NAME_ODOO=openmrs_eip_mgt_odoo
EIP_DB_USER_ODOO=openmrs_eip_mgt_odoo
EIP_DB_PASSWORD_ODOO=password
OPENMRS_URL=http://backend:8080/openmrs
OPENMRS_DB_HOST=db
OPENMRS_DB_PORT=3306
OPENMRS_DB_NAME=amrs
OPENMRS_DB_USER=openmrs
OPENMRS_DB_PASSWORD=openmrs
OPENMRS_USER=admin
OPENMRS_PASSWORD=Admin123
EIP_FHIR_SERVER_URL=http://backend:8080/openmrs/ws/fhir2/R4
EIP_ODOO_FHIR_SERVER_URL=http://fhir-odoo:8080/odoo/fhir/R4
EIP_PRODUCT_SYNC_INITIAL_DELAY=60000
EIP_PRODUCT_SYNC_DELAY=86400000
EIP_ODOO_OPENMRS_ROUTES_PATH=./eip-odoo-openmrs-routes

# Optional: override Odoo/Postgres images (defaults: ghcr.io/ampath/o3-amrs-odoo-postgres:latest, ghcr.io/ampath/o3-amrs-odoo:latest)
# ODOO_POSTGRES_IMAGE=ghcr.io/ampath/o3-amrs-odoo-postgres:3.6.0
# ODOO_IMAGE=ghcr.io/ampath/o3-amrs-odoo:3.6.0

# Distro / env-substitution (path to files for env-substitution)
DISTRO_PATH=.
